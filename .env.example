# Copy to .env and fill in. The .env file is gitignored; secrets never enter the repo.

ANTHROPIC_API_KEY=sk-ant-...

# snapshot = local CSVs (development/testing). live = Snowflake (demo).
DATA_MODE=snapshot

# The synthetic dataset's clock stops at 2026-05-31. The agent's "today" is
# anchored just after so relative-time logic behaves as it would in production.
AS_OF_DATE=2026-06-01

# Only needed when DATA_MODE=live
SNOWFLAKE_ACCOUNT=PERSONIO-SANDBOX
SNOWFLAKE_USER=...
SNOWFLAKE_PASSWORD=...
SNOWFLAKE_WAREHOUSE=COMPUTE_XS_WH
# For human users with MFA (password auth is blocked programmatically):
# opens the normal web login once and caches the token.
SNOWFLAKE_AUTHENTICATOR=externalbrowser
