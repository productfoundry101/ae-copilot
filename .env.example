# Copy to .env and fill in your keys. The .env file is gitignored; secrets
# never enter the repo. On Streamlit Cloud, set these as app secrets instead.

# --- LLM provider: openai | anthropic ---
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Data: snapshot (local CSVs) | live (Snowflake) ---
# snapshot = self-contained, runs anywhere (dev, tests, hosted demo)
# live     = queries Snowflake directly (identical SQL)
DATA_MODE=snapshot

# The synthetic dataset's clock stops at 2026-05-31. The agent's "today" is
# anchored just after so relative-time logic behaves as it would in production.
AS_OF_DATE=2026-06-01

# --- Only needed when DATA_MODE=live -------------------------------------
SNOWFLAKE_ACCOUNT=PERSONIO-SANDBOX
SNOWFLAKE_USER=...
SNOWFLAKE_WAREHOUSE=COMPUTE_XS_WH
# Pick ONE auth method (service account with key-pair is the production choice):
# SNOWFLAKE_PASSWORD=...            # service accounts only; blocked for MFA users
# SNOWFLAKE_PAT=...                 # programmatic access token
# SNOWFLAKE_PRIVATE_KEY_PATH=...    # key-pair auth
# SNOWFLAKE_AUTHENTICATOR=externalbrowser  # human SSO login (needs SAML IdP)

# --- Optional: verbose runtime narration to the terminal -----------------
# COPILOT_DEBUG=1   # agent loop: turns, round-trips, tool calls
# COPILOT_DEBUG=2   # also prints every SQL query
